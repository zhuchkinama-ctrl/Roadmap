<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.8.xsd">

    <changeSet id="004" author="team@trackhub">
        <createTable tableName="track_permissions">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="track_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="role" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addForeignKeyConstraint baseTableName="track_permissions" baseColumnNames="track_id"
                                 referencedTableName="tracks" referencedColumnNames="id"
                                 constraintName="fk_track_permissions_track"/>
        <addForeignKeyConstraint baseTableName="track_permissions" baseColumnNames="user_id"
                                 referencedTableName="users" referencedColumnNames="id"
                                 constraintName="fk_track_permissions_user"/>
        <addUniqueConstraint tableName="track_permissions" columnNames="track_id,user_id"
                                 constraintName="uq_track_user"/>
        <rollback>
            <dropTable tableName="track_permissions"/>
        </rollback>
    </changeSet>

</databaseChangeLog>